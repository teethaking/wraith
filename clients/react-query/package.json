{
  "name": "@wraith/react-query",
  "version": "0.1.0",
  "description": "Typed React Query hooks for the Wraith REST API, generated from its OpenAPI spec",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "generate": "openapi-typescript ../../openapi.json -o src/schema.d.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
